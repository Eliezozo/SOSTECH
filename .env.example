# ─────────────────────────────────────────────────────────────
# Sostech Systems — Environment variables
# Copy this file to ".env.local" and fill in the real values.
# On Vercel, add the same variables in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase (admin auth, media storage, dynamic content) ──
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Storage bucket name (create a PUBLIC bucket with this name)
NEXT_PUBLIC_SUPABASE_BUCKET=media

# ── Contact form email (Nodemailer SMTP) ──
# Example for Gmail: host=smtp.gmail.com, port=465, secure=true,
#   user=your@gmail.com, pass=an "App Password" (not your normal password).
# Example for AOL:   host=smtp.aol.com,  port=465, secure=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password

# Where contact messages are delivered, and the "from" address shown.
CONTACT_TO=sostechgh@aol.com
CONTACT_FROM="Sostech Systems Website <your-address@gmail.com>"
